PORT=3000
NODE_ENV=development

JWT_SECRET=substitua-por-um-segredo-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=2h

AUTH_COOKIE_NAME=portfolio_session
AUTH_COOKIE_MAX_AGE=7200
CSRF_COOKIE_NAME=portfolio_csrf

ALLOWED_ORIGIN=http://localhost:5500
TRUST_PROXY=false

RATE_LIMIT_WINDOW_MS=60000
MAX_CONTACT_REQUESTS=15
MAX_AUTH_REQUESTS=10

# Desenvolvimento e testes locais:
DATABASE_PROVIDER=sqlite
DATABASE_PATH=

# Produção com Supabase:
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_CA_PATH=certs/supabase-ca.crt
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

LOG_FILE_PATH=
